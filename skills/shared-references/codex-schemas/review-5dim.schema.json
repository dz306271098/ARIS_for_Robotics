{
  "type": "object",
  "properties": {
    "dimensions": {
      "type": "object",
      "properties": {
        "novelty": { "type": "integer", "minimum": 1, "maximum": 10 },
        "technical_soundness": { "type": "integer", "minimum": 1, "maximum": 10 },
        "experimental_rigor": { "type": "integer", "minimum": 1, "maximum": 10 },
        "clarity": { "type": "integer", "minimum": 1, "maximum": 10 },
        "significance": { "type": "integer", "minimum": 1, "maximum": 10 }
      },
      "required": ["novelty", "technical_soundness", "experimental_rigor", "clarity", "significance"],
      "additionalProperties": false
    },
    "overall_score": { "type": "number", "minimum": 1, "maximum": 10 },
    "verdict": { "type": "string", "enum": ["READY", "ALMOST", "NOT_READY"] },
    "blocking_weaknesses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dimension": { "type": "string" },
          "description": { "type": "string" },
          "minimum_fix": { "type": "string" }
        },
        "required": ["dimension", "description", "minimum_fix"],
        "additionalProperties": false
      }
    },
    "strengthening_weaknesses": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dimension": { "type": "string" },
          "description": { "type": "string" },
          "suggested_fix": { "type": "string" }
        },
        "required": ["dimension", "description", "suggested_fix"],
        "additionalProperties": false
      }
    },
    "changes_to_flip_ready": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["dimensions", "overall_score", "verdict", "blocking_weaknesses", "strengthening_weaknesses"],
  "additionalProperties": false
}
