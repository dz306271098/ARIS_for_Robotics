{
  "type": "object",
  "properties": {
    "design_verdict": { "type": "string", "enum": ["sound", "needs_revision", "fundamentally_flawed"] },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] },
          "category": { "type": "string", "enum": ["baseline_fairness", "statistical_rigor", "metric_choice", "data_leakage", "implementation_bug", "missing_experiment", "overclaiming"] },
          "description": { "type": "string" },
          "file": { "type": "string" },
          "fix": { "type": "string" }
        },
        "required": ["severity", "category", "description", "fix"],
        "additionalProperties": false
      }
    },
    "baseline_fairness_audit": {
      "type": "object",
      "properties": {
        "hyperparameter_parity": { "type": "boolean" },
        "training_schedule_aligned": { "type": "boolean" },
        "data_splits_identical": { "type": "boolean" },
        "compute_parity": { "type": "boolean" },
        "baselines_recent": { "type": "boolean" }
      },
      "required": ["hyperparameter_parity", "training_schedule_aligned", "data_splits_identical"],
      "additionalProperties": false
    },
    "statistical_rigor_check": {
      "type": "object",
      "properties": {
        "seeds_sufficient": { "type": "boolean" },
        "mean_std_computed": { "type": "boolean" },
        "significance_test_present": { "type": "boolean" },
        "error_bars_in_plots": { "type": "boolean" }
      },
      "required": ["seeds_sufficient", "mean_std_computed"],
      "additionalProperties": false
    }
  },
  "required": ["design_verdict", "issues", "baseline_fairness_audit", "statistical_rigor_check"],
  "additionalProperties": false
}
